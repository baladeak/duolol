# Porta que o servidor vai rodar (EasyPanel expõe esta porta)
PORT=3000

# ── Banco de dados (Hostinger MySQL) ──────────
# Encontre no painel Hostinger > Hospedagem > Banco de Dados > Detalhes
DB_HOST=srv1082.hstgr.io
DB_PORT=3306
DB_NAME=u715603993_duolol
DB_USER=u715603993_duolol
DB_PASSWORD=Tututeamo@123

# ── Segurança ─────────────────────────────────
# Gere uma string aleatória longa. Exemplo no terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cole_aqui_uma_string_longa_e_aleatoria_minimo_32_caracteres

# ── Riot Games API ────────────────────────────
# Obtenha em: https://developer.riotgames.com
# Development Key dura 24h (para testes)
# Production Key requer aprovação da Riot
RIOT_API_KEY=RGAPI-cc0c611e-617c-4f9a-ab90-39d4b5270d1c

# Região do servidor LoL (br1, na1, euw1, etc.)
RIOT_REGION=br1
